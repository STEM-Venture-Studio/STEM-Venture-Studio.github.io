---

<section class="py-20 md:py-28 bg-surface-container-lowest overflow-hidden">
  <div class="mx-auto max-w-7xl px-6 lg:px-8 grid grid-cols-1 lg:grid-cols-2 items-center gap-16">
    <div class="order-2 lg:order-1">
      <img
        src="/images/sections/stim-sense.webp"
        alt="STIM Sense Technology"
        class="w-full rounded-[var(--radius)] shadow-[0_8px_32px_rgba(0,71,66,0.08)]"
        loading="lazy"
      />
    </div>
    <div class="order-1 lg:order-2 space-y-8">
      <div class="space-y-4">
        <h2 class="text-3xl md:text-4xl font-extrabold text-on-surface uppercase leading-tight" style="font-family: var(--font-headline);">
          Presenting...<br/>STIM Sense Technology
        </h2>
        <div class="w-16 h-1 bg-primary-container"></div>
        <p class="text-xl font-bold text-primary tracking-widest uppercase">
          Sense | Measure | Control | Connect
        </p>
      </div>
      <p class="text-on-surface/70 text-lg leading-relaxed">
        We design & manufacture sensors and products, with LPWAN connectivity, for your IOT solutions, so YOU can focus on making your business work.
      </p>
      <a
        href="#contact"
        class="inline-block rounded-[var(--radius)] text-white px-10 py-4 font-bold hover:brightness-110 transition-all"
        style="background: linear-gradient(135deg, #006a63, #35bdb2);"
      >
        Contact STIM Canada TODAY
      </a>
    </div>
  </div>
</section>