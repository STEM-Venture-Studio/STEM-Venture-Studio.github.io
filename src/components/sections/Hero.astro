---
---

<section
  class="relative min-h-[700px] flex items-center justify-center overflow-hidden"
  aria-label="Hero"
>
  <div class="absolute inset-0 z-0">
    <img
      src="/images/hero/pcb-closeup.webp"
      alt=""
      class="w-full h-full object-cover"
      fetchpriority="high"
      loading="eager"
    />
    <div class="absolute inset-0 bg-black/55"></div>
  </div>

  <div class="relative z-10 max-w-4xl px-8 text-center">
    <div class="mb-8 flex justify-center">
      <img src="/logos/stim-canada-rectangle.svg" alt="STIM Canada" class="h-12 md:h-16 w-auto brightness-0 invert" />
    </div>
    <h1 class="text-white text-3xl md:text-5xl font-extrabold mb-4 tracking-tight leading-tight" style="font-family: var(--font-headline);">
      Precision Manufacturing for<br />Life-Critical Electronics
    </h1>
    <p class="text-white/80 text-lg md:text-xl mb-10 max-w-2xl mx-auto">
      Enabling technologies of the future through specialist PCBA, Box-Build, and Supply Chain Solutions — all under one ISO 13485 certified roof.
    </p>
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
      <a
        href="#contact"
        class="inline-flex items-center rounded-[var(--radius)] px-10 py-3.5 text-base font-bold text-white hover:brightness-110 transition-all"
        style="background: linear-gradient(135deg, #006a63, #35bdb2);"
      >
        REQUEST A QUOTE
      </a>
      <a
        href="#services"
        class="inline-flex items-center gap-2 border-2 border-white/70 text-white px-10 py-3.5 rounded-[var(--radius)] font-bold hover:bg-white/10 transition-colors"
        style="transition-duration: var(--duration-fast);"
      >
        OUR SERVICES
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="m6 9 6 6 6-6"/>
        </svg>
      </a>
    </div>
  </div>
</section>