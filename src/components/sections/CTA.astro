---
---

<section
  id="contact"
  class="relative py-24 flex items-center"
  aria-label="Contact"
>
  <div class="absolute inset-0 z-0">
    <img
      src="/images/sections/cta-bg.webp"
      alt=""
      class="w-full h-full object-cover"
      loading="lazy"
    />
    <div class="absolute inset-0 bg-black/70"></div>
  </div>

  <div class="relative z-10 max-w-7xl mx-auto px-6 lg:px-8 flex flex-col md:flex-row justify-between items-center gap-12 w-full">
    <div class="text-white text-center md:text-left max-w-2xl">
      <h2 class="text-4xl md:text-5xl font-extrabold mb-4 uppercase" style="font-family: var(--font-headline);">
        Contact Us
      </h2>
      <div class="w-16 h-1 bg-primary-container mb-6 mx-auto md:mx-0"></div>
      <p class="text-xl text-white/80">
        To request a quote, find out more about our services or to simply talk through your project... get in touch today!
      </p>
    </div>
    <a
      href="mailto:sales@stimcanada.com"
      class="inline-flex items-center gap-2 rounded-[var(--radius)] px-10 py-4 font-bold text-lg text-white shadow-lg hover:brightness-110 transition-all"
      style="background: linear-gradient(135deg, #006a63, #35bdb2); transition-duration: var(--duration-fast);"
    >
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
      </svg>
      STIM Contact Form
    </a>
  </div>
</section>