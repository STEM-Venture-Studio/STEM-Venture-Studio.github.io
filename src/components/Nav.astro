---
const navLinks = [
  { href: '#services', label: 'Services' },
  { href: '#value-added', label: 'Value Added' },
  { href: '#markets', label: 'Markets' },
  { href: '#quality', label: 'Quality' },
];
---

<header class="fixed top-0 left-0 right-0 z-50 bg-white/80 backdrop-blur-[20px] shadow-[0_8px_32px_rgba(0,71,66,0.08)]">
  <nav
    class="mx-auto max-w-7xl px-6 lg:px-8 h-16 flex items-center justify-between"
    aria-label="Main navigation"
  >
    <a
      href="#"
      class="flex items-center gap-3 hover:opacity-80 transition-opacity"
      style="transition-duration: var(--duration-fast);"
      aria-label="STIM Canada — home"
    >
      <img src="/logos/stim-canada-rectangle.svg" alt="STIM Canada" class="h-8 w-auto" />
    </a>

    <ul class="hidden md:flex items-center gap-8 list-none m-0 p-0">
      {navLinks.map(({ href, label }) => (
        <li>
          <a
            href={href}
            class="text-sm font-medium text-on-surface/70 hover:text-primary transition-colors"
            style="transition-duration: var(--duration-fast);"
          >
            {label}
          </a>
        </li>
      ))}
    </ul>

    <div class="flex items-center gap-6">
      <div class="hidden lg:flex flex-col items-end">
        <span class="text-xs text-on-surface/40 uppercase tracking-widest">Call Us</span>
        <a href="tel:+14166364584" class="text-primary font-bold text-sm hover:text-primary-container transition-colors">(416) 636 4584</a>
      </div>
      <a
        href="#contact"
        class="inline-flex items-center rounded-[var(--radius)] bg-primary px-5 py-2.5 text-sm font-bold text-white hover:brightness-110 transition-all"
        style="background: linear-gradient(135deg, #006a63, #35bdb2); transition-duration: var(--duration-fast);"
      >
        GET A QUOTE
      </a>
    </div>
  </nav>
</header>